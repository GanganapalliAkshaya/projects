import tkinter as tk
from tkinter import colorchooser

pen_color = "black"
pen_size = 3
last_x = last_y = None

def start_draw(event):
    global last_x, last_y
    last_x, last_y = event.x, event.y

def draw(event):
    global last_x, last_y
    if last_x is not None and last_y is not None:
        canvas.create_line(last_x, last_y, event.x, event.y,
                           fill=pen_color, width=pen_size,
                           capstyle=tk.ROUND, smooth=True)
    last_x, last_y = event.x, event.y

def reset(event):
    global last_x, last_y
    last_x = last_y = None

def choose_color():
    global pen_color
    color = colorchooser.askcolor()[1]
    if color:
        pen_color = color

def set_size(val):
    global pen_size
    pen_size = int(val)

def clear_canvas():
    canvas.delete("all")

root = tk.Tk()
root.title("Drawing Pad")

toolbar = tk.Frame(root, bg="#e0e0e0", pady=4)
toolbar.pack(fill=tk.X)
tk.Button(toolbar, text="Color", command=choose_color,
          bg="#1565c0", fg="white").pack(side=tk.LEFT, padx=4)
tk.Button(toolbar, text="Clear", command=clear_canvas,
          bg="#c62828", fg="white").pack(side=tk.LEFT, padx=4)
tk.Label(toolbar, text="Size:", bg="#e0e0e0").pack(side=tk.LEFT)
tk.Scale(toolbar, from_=1, to=20, orient=tk.HORIZONTAL,
         command=set_size, bg="#e0e0e0").pack(side=tk.LEFT)

canvas = tk.Canvas(root, bg="white", width=600, height=450,
                   cursor="crosshair")
canvas.pack()
canvas.bind("<ButtonPress-1>", start_draw)
canvas.bind("<B1-Motion>", draw)
canvas.bind("<ButtonRelease-1>", reset)

root.mainloop()
